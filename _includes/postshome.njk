
{% for post in postslist | reverse %}
<article>
<header>
<h2 class="dayHeader"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
{%- if not post.data.tags.includes("journal") %}
<div class="post-meta">{{ post.date | readableDate("DD") }}</div>
{%- endif %}
</header>
{{ post.content | safe }}
</article>
{% endfor %}
